FILE=TABLE
PRODUCT=libwda
#
Group:
  FLAVOR=ANY
  QUALIFIERS=""
    ACTION=SETUP
        setupEnv()
        proddir()
        envPrepend(LD_LIBRARY_PATH,${UPS_PROD_DIR}/lib)
        envPrepend(LIBRARY_PATH,${UPS_PROD_DIR}/lib)
        # make Art framework build happier...
        envSet(LIBWDA_VERSION, ${UPS_PROD_VERSION})
        envSet(LIBWDA_LIB, ${UPS_PROD_DIR}/lib)
        envSet(LIBWDA_FQ_DIR, ${UPS_PROD_DIR})

End:

